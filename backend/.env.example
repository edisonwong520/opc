# Security: Change DJANGO_SECRET_KEY for production!
DJANGO_SECRET_KEY=django-insecure-ceo-desk-dev-key-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,testserver
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPC_REQUIRE_AUTH=false
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# PostgreSQL:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=opc
# DB_USER=opc
# DB_PASSWORD=replace-with-local-password
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_CONN_MAX_AGE=60
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:7788
OPENCLAW_GATEWAY_AUTH_MODE=token
OPENCLAW_GATEWAY_TOKEN=replace-with-token-from-openclaw-config
OPENCLAW_GATEWAY_PASSWORD=

# OpenAI-compatible model settings, aligned with wanny.
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=sk-your-ai-key-here
AI_MODEL=deepseek-chat
OPC_COST_INPUT_PER_1K_USD=0
OPC_COST_OUTPUT_PER_1K_USD=0

# Optional native Gemini settings for future integrations.
GEMINI_API_KEY=
GEMINI_MODEL=
