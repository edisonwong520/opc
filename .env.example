OPENCLAW_GATEWAY_URL=ws://127.0.0.1:7788
OPENCLAW_GATEWAY_AUTH_MODE=token
OPENCLAW_GATEWAY_TOKEN=replace-with-token-from-openclaw-config
OPENCLAW_GATEWAY_PASSWORD=

# OpenAI-compatible model settings, aligned with wanny.
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=sk-your-ai-key-here
AI_MODEL=deepseek-chat

# Optional native Gemini settings for future integrations.
GEMINI_API_KEY=
GEMINI_MODEL=
